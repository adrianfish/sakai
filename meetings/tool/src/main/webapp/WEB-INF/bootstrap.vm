                </span>
                {if meeting.canEnd}
                {var end_meetingClass = (meeting.joinable && meeting.joinableMode == 'inprogress')? "meetings_end_meeting_shown": "meetings_end_meeting_hidden" }
                <div id="end_meeting_intermediate_${D}{meeting.id}" class="${D}{end_meetingClass}" >
                    &nbsp;|&nbsp;
                    <a id="end_session_link" href="javascript:;" onclick="return meetings.utils.endMeeting('${D}{escape(meeting.name)}','${D}{meeting.id}');" title="${D}{meetings_action_end_meeting_tooltip}" style="font-weight:bold">${D}{meetings_action_end_meeting}</a>
                    <span><i class="fa fa-stop"></i></span>
                </div>
                {/if}
                )
            <span>
        </td>
      </tr>
      <tr id="meetings_meeting_info_participants_count_tr" style="display:none">
        <td><h5>${D}{meetings_meetinginfo_participants_count}</h5></td>
        <td>
            <span id="meetings_meeting_info_participants_count"></span>
            <a id="updateMeetingInfo" href="javascript:;" onclick="meetings.utils.checkOneMeetingAvailability('${D}{meeting.id}'); return false;" title="${D}{meetings_meetinginfo_updateinfo_tooltip}">
                <i class="fa fa-refresh" title="${D}{meetings_refresh}"></i>
            </a>
        </td>
